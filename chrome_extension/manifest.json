{
  "manifest_version": 3,
  "name": "Shield360 - Shadow IT Agent",
  "description": "Automatically scans visited URLs for phishing, malware, and defacement threats via local ML engine.",
  "version": "1.0.0",
  "permissions": [
    "tabs",
    "webNavigation",
    "notifications"
  ],
  "host_permissions": [
    "http://127.0.0.1:5001/*",
    "http://localhost:5001/*",
    "http://127.0.0.1:5173/*",
    "http://localhost:5173/*",
    "https://*.onrender.com/*",
    "https://shield360-api.onrender.com/*",
    "https://shield-360-1.onrender.com/*",
    "https://*.vercel.app/*"
  ],
  "background": {
    "service_worker": "background.js"
  },
  "action": {
    "default_popup": "popup.html"
  },
  "icons": {
    "48": "icon48.png",
    "128": "icon128.png"
  }
}
